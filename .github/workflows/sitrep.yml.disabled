# Morning sitrep — DISABLED.
# Rename to sitrep.yml once both TODO steps below exist. Not before: a
# scheduled workflow that does nothing still costs minutes and trust.
#
# The shape matters more than the contents:
#   1. a deterministic script decides whether anything changed;
#   2. a headless model call runs only if it did.
# The model never decides whether to wake up.

name: Morning sitrep

on:
  workflow_dispatch: {}
  # schedule:
